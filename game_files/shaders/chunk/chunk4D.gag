
#version 460 core
layout (points) in;
layout (triangle_strip, max_vertices = 6) out;

in uint cellData[1];

out vec3 uv;

out vec3 viewSpace_normal;

uniform mat4 pv;
uniform mat3 normal_mat;

//all of deez should be normalized
