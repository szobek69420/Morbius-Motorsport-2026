#version 460 core
in vec3 uv;
in vec3 viewSpace_normal;
in vec3 viewSpace_position;

layout (location = 0) out vec4 gPosition;
layout (location = 1) out vec3 gNormal;
layout (location = 2) out vec3 gAlbedo;

layout (binding=0) uniform sampler2DArray blockTextures;

void main()
{
	gPosition=vec4(viewSpace_position.xy, -viewSpace_position.z, 1.0); //for some fucking reason the z coordinate is flipped
	gNormal=viewSpace_normal;
	gAlbedo=texture(blockTextures, uv).rgb;
}